binds {
    // -----------------------------
    // Window / session
    // -----------------------------
    Mod+W repeat=false { close-window; }

    // Hyprland had togglefloating + centerwindow on Mod+F.
    // Niri has no single exact equivalent, so this just toggles floating.
    Mod+F { toggle-window-floating; }

    // Mod+Alt+M { maximize-window-to-edges; }
    // Mod+M { fullscreen-window; }

    // No native sticky/pin toggle in niri yet.
    // Mod+P { ... }

    // -----------------------------
    // System
    // -----------------------------
    Mod+BackSpace { spawn-sh "~/.dotfiles/bin/.local/share/bin/logoutlaunch.sh"; }

    // -----------------------------
    // Application shortcuts
    // -----------------------------
    Mod+Return { spawn "kitty" "-1"; }
    Mod+E { spawn "nautilus"; }

    // Edit this session path if needed.
    Mod+U {
        spawn-sh "~/.dotfiles/bin/.local/share/bin/open-obsidian-nvim.sh";
    }

    Mod+O { spawn "obsidian"; }
    Mod+V { spawn "zathura"; }
    Mod+Shift+V { spawn-sh "kitty zsh -lc 'search_pdf.sh'"; }
    Mod+Shift+Return { spawn "zen"; }

    Mod+B {
        spawn-sh "pkill -x btop || exec kitty --class=system_monitor -o window_padding_width=0 btop";
    }

    Mod+Shift+B {
        spawn-sh "pkill -x nvtop || exec kitty --class=system_monitor -o window_padding_width=0 nvtop";
    }

    Mod+Ctrl+W { spawn-sh "~/.dotfiles/bin/.local/share/bin/toggle_waybar.sh"; }

    Mod+Z { spawn-sh "zotero"; }
    Mod+G { spawn "xdg-open" "https://chatgpt.com"; }
    // Mod+Q { spawn-sh "~/.dotfiles/bin/.local/share/bin/toggle_kitty.sh musicfox"; }
    Mod+I { spawn-sh "~/.dotfiles/bin/.local/share/bin/quick_latex.sh"; }

    // -----------------------------
    // Screenshot / recording
    // -----------------------------
    F1 { spawn-sh "grimblast copy area \"$HOME/Pictures/Screenshots/$(date +'%F-%T.png')\""; }
    F2 { spawn-sh "grimblast copysave area \"$HOME/Pictures/Screenshots/$(date +'%F-%T.png')\""; }
    F3 { spawn-sh "~/.dotfiles/bin/.local/share/bin/wf-recorder-toggle.sh"; }
    F4 { spawn-sh "~/.dotfiles/bin/.local/share/bin/clip2float.sh"; }

    // -----------------------------
    // Audio
    // -----------------------------
    F10 allow-when-locked=true { spawn-sh "~/.dotfiles/bin/.local/share/bin/volumecontrol-pipewire.sh -o m"; }
    F11 allow-when-locked=true { spawn-sh "~/.dotfiles/bin/.local/share/bin/volumecontrol-pipewire.sh -o d"; }
    F12 allow-when-locked=true { spawn-sh "~/.dotfiles/bin/.local/share/bin/volumecontrol-pipewire.sh -o i"; }

    XF86AudioMute allow-when-locked=true { spawn-sh "~/.dotfiles/bin/.local/share/bin/volumecontrol-pipewire.sh -o m"; }
    XF86AudioMicMute allow-when-locked=true { spawn-sh "~/.dotfiles/bin/.local/share/bin/volumecontrol-pipewire.sh -i m"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "~/.dotfiles/bin/.local/share/bin/volumecontrol-pipewire.sh -o d 2"; }
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "~/.dotfiles/bin/.local/share/bin/volumecontrol-pipewire.sh -o i 2"; }

    F9 allow-when-locked=true { spawn-sh "~/.dotfiles/bin/.local/share/bin/volumecontrol.sh -s ''"; }

    // -----------------------------
    // Media
    // -----------------------------
    XF86AudioPlay allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPause allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioNext allow-when-locked=true { spawn "playerctl" "next"; }
    XF86AudioPrev allow-when-locked=true { spawn "playerctl" "previous"; }

    Mod+Ctrl+Space { spawn "playerctl" "play-pause"; }
    Mod+Ctrl+Right { spawn "playerctl" "next"; }
    Mod+Ctrl+Left { spawn "playerctl" "previous"; }

    // -----------------------------
    // Brightness
    // -----------------------------
    XF86MonBrightnessUp allow-when-locked=true { spawn-sh "~/.dotfiles/bin/.local/share/bin/brightnesscontrol.sh i"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn-sh "~/.dotfiles/bin/.local/share/bin/brightnesscontrol.sh d"; }

    // -----------------------------
    // Custom scripts
    // -----------------------------
    // Mod+Alt+G { spawn-sh "~/.dotfiles/bin/.local/share/bin/gamemode.sh"; }
    Mod+Shift+W { spawn "waypaper"; }

    Mod+Space {
        spawn-sh "pkill -x rofi || exec rofi -show drun -theme $HOME/.config/rofi/config.rasi";
    }
}
